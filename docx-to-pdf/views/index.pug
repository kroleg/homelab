extends layout

block content
  style.
    .container {
      max-width: 40rem;
      margin: 0 auto;
      padding: 2rem 1rem;
      width: 100%;
    }
    .drop-zone {
      border: 2px dashed #d4d4d8;
      border-radius: 0.75rem;
      padding: 3rem 1.5rem;
      text-align: center;
      cursor: pointer;
      transition: border-color 0.15s, background 0.15s;
    }
    .drop-zone:hover, .drop-zone.dragover {
      border-color: var(--primary);
      background: var(--primary-fg);
    }
    .drop-zone-icon {
      font-size: 2.5rem;
      margin-bottom: 0.75rem;
    }
    .drop-zone-text {
      color: var(--muted);
      font-size: 0.95rem;
    }
    .drop-zone-text strong {
      color: var(--primary);
    }
    .file-name {
      margin-top: 1rem;
      font-size: 0.875rem;
      color: var(--foreground);
      font-weight: 500;
    }
    .status {
      margin-top: 1rem;
      padding: 0.75rem;
      background: var(--secondary);
      color: var(--muted);
      border-radius: 0.5rem;
      font-size: 0.875rem;
      text-align: center;
    }
    .status .spinner {
      display: inline-block;
      width: 0.875rem;
      height: 0.875rem;
      border: 2px solid var(--muted);
      border-top-color: transparent;
      border-radius: 50%;
      animation: spin 0.6s linear infinite;
      vertical-align: middle;
      margin-right: 0.5rem;
    }
    .error {
      margin-top: 1rem;
      padding: 0.75rem;
      background: #fef2f2;
      color: #dc2626;
      border-radius: 0.5rem;
      font-size: 0.875rem;
    }
    @keyframes spin { to { transform: rotate(360deg); } }

  .container
    form#upload-form(action="/api/convert" method="POST" enctype="multipart/form-data")
      .drop-zone#drop-zone
        .drop-zone-icon 📄
        .drop-zone-text
          | Перетащите файл сюда или #[strong нажмите для выбора]
          br
          | .doc / .docx
        .file-name#file-name
        input(type="file" name="file" accept=".doc,.docx" hidden)#file-input
      .status#status(style="display:none")
      .error#error(style="display:none")

  script.
    const dropZone = document.getElementById('drop-zone');
    const fileInput = document.getElementById('file-input');
    const fileName = document.getElementById('file-name');
    const statusEl = document.getElementById('status');
    const errorEl = document.getElementById('error');
    let converting = false;

    dropZone.addEventListener('click', () => {
      if (!converting) fileInput.click();
    });

    dropZone.addEventListener('dragover', (e) => {
      e.preventDefault();
      dropZone.classList.add('dragover');
    });

    dropZone.addEventListener('dragleave', () => {
      dropZone.classList.remove('dragover');
    });

    dropZone.addEventListener('drop', (e) => {
      e.preventDefault();
      dropZone.classList.remove('dragover');
      if (!converting && e.dataTransfer.files.length) {
        convert(e.dataTransfer.files[0]);
      }
    });

    fileInput.addEventListener('change', () => {
      if (fileInput.files.length) {
        convert(fileInput.files[0]);
      }
    });

    async function convert(file) {
      if (converting) return;
      converting = true;
      fileName.textContent = file.name;
      errorEl.style.display = 'none';
      statusEl.style.display = 'block';
      statusEl.textContent = '';
      const spinner = document.createElement('span');
      spinner.className = 'spinner';
      statusEl.appendChild(spinner);
      statusEl.appendChild(document.createTextNode('Конвертация...'));

      try {
        const formData = new FormData();
        formData.append('file', file);
        const resp = await fetch('/api/convert', { method: 'POST', body: formData });

        if (!resp.ok) {
          const data = await resp.json();
          throw new Error(data.error || 'Conversion failed');
        }

        const blob = await resp.blob();
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = file.name.replace(/\.docx?$/i, '.pdf');
        a.click();
        URL.revokeObjectURL(url);
        statusEl.style.display = 'none';
      } catch (err) {
        statusEl.style.display = 'none';
        errorEl.textContent = err.message;
        errorEl.style.display = 'block';
      } finally {
        converting = false;
        fileInput.value = '';
      }
    }
